" General Settings
set configversion 2.0
set newtab about:blank
set leavegithubalone true

" Ignore mode
blacklistadd ondemand.anvil.rcac.purdue.edu

" Firefox settings

jsb tri.excmds.setpref("services.sync.addons.ignoreUserEnabledChanges", "true")  " Do not sync addon state
jsb tri.excmds.setpref("dom.serviceWorkers.enabled", "false")  " Disable service workers
jsb tri.excmds.setpref("browser.compactmode.show", "true")  " Enable compact density
