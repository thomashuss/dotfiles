#!/bin/sh

for var in '$DOTFILES_REPO' $($DOTFILES_REPO/.local/lib/dotfiles/scripts/fix_paths); do
	if eval "[ -z $var ]"; then
		echo "$var is not set.  Aborting."
		exit 1
	fi
done
files=$($DOTFILES_REPO/.local/lib/dotfiles/scripts/print_dotfiles)
echo "$files" | rsync --ignore-missing-args --files-from=- ~ "$DOTFILES_REPO"
cd "$DOTFILES_REPO" && $DOTFILES_REPO/.local/lib/dotfiles/scripts/fix_paths update $files
$DOTFILES_REPO/.local/lib/dotfiles/scripts/init_config update
echo "Done."
git status
exit 0
